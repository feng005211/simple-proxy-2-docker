# Required
EMAIL="you@example.com"
CF_TOKEN="your_cloudflare_api_token"

# Xray ports
DEFAULT_XRAY_PORT="24443"
DEFAULT_XRAY_VISION_PORT="23333"

# Xray runs as this non-root UID/GID and the TLS private key is owned by it.
XRAY_RUN_UID="65532"
XRAY_RUN_GID="65532"

# Hysteria 2 UDP port or port hopping range
DEFAULT_HY2_PORT_RANGE="40000-50000"

# IPv6 DNS automation
ENABLE_IPV6="true"

# Optional manual IP overrides
# PUBLIC_IPV4="1.2.3.4"
# PUBLIC_IPV6="2001:db8::1234"

# Optional Hysteria 2 tuning
HY2_BANDWIDTH_UP="1 gbps"
HY2_BANDWIDTH_DOWN="1 gbps"
HY2_CLIENT_BANDWIDTH_UP="1 gbps"
HY2_CLIENT_BANDWIDTH_DOWN="1 gbps"

# Optional REALITY settings. If omitted, the installer chooses one from the pool.
# REALITY_SNI="www.oracle.com"
# REALITY_TARGET="www.oracle.com:443"
REALITY_SNI_POOL="www.oracle.com,www.ibm.com,www.samsung.com,www.lg.com,developer.mozilla.org,source.android.com,www.intel.com,www.amd.com,www.lenovo.com,www.dell.com"
